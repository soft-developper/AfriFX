# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Turso Database
# Get URL:   turso db show afrifx --url
# Get token: turso db tokens create afrifx
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Super Admin Wallet
ADMIN_WALLET=0xYourWalletAddressHere

# Super Admin Credentials
ADMIN_USERNAME=superadmin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_strong_password

# Admin JWT — generate: openssl rand -hex 32
ADMIN_JWT_SECRET=generate_a_32_char_random_string_here

# Cloudinary — cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_27_char_api_secret
